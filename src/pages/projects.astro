---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";
import HeroImage from "../components/HeroImage.tsx";
import Contenido2 from "../components/Contenido2.tsx";
import Contenido3 from "../components/Contenido3.tsx";
import CallToAction from "../layouts/CallToAction.tsx";
import ImageGallery from "../components/ImageGallery.tsx";
---

<MainLayout>
  <Navbar client:load />
      <Banner title="Projects" image="bannerprojects-idaho-greencountry.webp" />

		<div class="container bg-white mx-auto px-4 pt-12">
			<div class="grid grid-cols-1 gap-8">
				<div class="flex flex-col justify-center" data-aos="fade-up">
					<h2 class="text-4xl font-bold text-stone-800">
						Projects and portfolio of
					</h2>
					<h3 class="text-2xl font-bold text-stone-800 mb-4">
						Green Country Landscaping Services LLC
					</h3>
					<p class="text-stone-700 leading-relaxed">
						Explore our recent projects and see the quality craftsmanship that defines Green Country Landscaping Services LLC. From custom landscapes and hardscapes to complete outdoor transformations, our gallery showcases the care, precision, and attention to detail we bring to every property across Idaho. Let our work inspire your next outdoor project.
					</p>
				</div>
			</div>
        </div>

		<div class="container bg-white mx-auto px-4 py-12">
			<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
				<div class="grid gap-6" data-aos="fade-up">
					<div>
						<ImageGallery image="project1-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project2-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project3-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="100">
					<div>
						<ImageGallery image="project4-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project5-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project6-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="200">
					<div>
						<ImageGallery image="project7-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project8-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project9-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="300">
					<div>
						<ImageGallery image="project10-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project11-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="project12-greencountry.webp" />
					</div>
				</div>
			</div>
		</div>

		<HeroImage text="Bringing life back to your landscape" image="project13-greencountry.webp" />

		<Contenido2
			title = "Nursery products"
			subtitle = "Large inventory and immediate availability"
			contenido = "Our nursery offers a wide selection of high-quality trees, shrubs, ornamental plants, and seasonal varieties suited for Idaho’s climate. With several acres of growing space, we maintain a large inventory and immediate availability for residential and commercial projects. Whether you're looking for shade trees, privacy hedges, or decorative landscaping plants, we provide healthy, well-cared-for stock ready for pickup or installation."
			image = "services3-greencountry.webp"
		/>

		<HeroImage text="Your outdoor vision, expertly crafted" image="services4-greencountry.webp" />

		<Contenido3
			title="Lawn care services"
			subtitle="Transforming outdoor spaces"
			contenido="Our professional lawn care services keep your property healthy, green, and well-maintained year-round. From routine mowing and edging to fertilization and seasonal maintenance, we provide reliable service tailored to Idaho’s climate. We focus on precision, consistency, and long-term lawn health to ensure your outdoor space always looks its best."
			image="services5-greencountry.webp"
		/>

	  <CallToAction />
  <Footer client:load />
</MainLayout>
