---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";
import HeroImage from "../components/HeroImage.tsx";
import Contenido1 from "../components/Contenido1.tsx";
import Contenido2 from "../components/Contenido2.tsx";
import Contenido3 from "../components/Contenido3.tsx";
import Contenido4 from "../components/Contenido4.tsx";
import CallToAction from "../layouts/CallToAction.tsx";


const contenidoChoose = [
	"Committed to delivering exceptional outdoors",
	"Serving Idaho, including the Nampa area",
	"Our experienced team work at your service",
	"From landscape and hardscape installations",
	"Professional lawn care and nursery products",
	"We focus on detail and durability",
	"You choose reliability and transparency",
	"Team dedicated to exceeding your expectations"
];

const contenidoServing = [
	"Caldwell, ID",
	"Nampa, ID",
	"Meridian, ID",
	"Boise, ID",
	"Eagle, ID",
	"Middleton, ID",
	"Star, ID",
	"Kuna, ID",
	"Wilder, ID",
	"Marsing, ID"
];

---

<MainLayout>
  <Navbar client:load />
      <Banner title="About Us" image="landscapingservices1-idaho-greencountry.webp" />

	  <Contenido1 
		title="Our company"
		subtitle="Our Commitment"
		contenido="Green Country Landscaping Services LLC is committed to delivering high-quality landscaping solutions with professionalism, reliability, and attention to detail. Proudly serving Idaho, including the Nampa area, we specialize in Landscape and Hardscape design, comprehensive Lawn Care services, and premium Nursery products. Our team is dedicated to enhancing outdoor spaces with craftsmanship, sustainable practices, and a strong commitment to customer satisfaction. Whether it’s maintaining a beautiful lawn or creating a complete outdoor transformation, we work with integrity and excellence in every project."
		image="logo3d-greencountry.webp"
	  />

	<div class="container mx-auto pt-12 md:pb-12">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="flex flex-col justify-center" data-aos="fade-up">
				<audio controls class="w-1/2 mx-auto mb-5">
				<source src="/audio/audio-greencountry.mp3" type="audio/mpeg" />
				Your browser does not support the audio element.
				</audio>
			</div>
		</div>
	</div>

      <HeroImage text="Trusted professional landscaping services in Idaho" image="aboutus1-greencountry.webp" />

      <div class="mx-auto px-0 py-16 bg-stone-100">
        <h2 class="text-2xl md:text-3xl font-bold text-stone-800 text-center mb-12">Mission, Vision and Values</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 mx-8">
			<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up">
				<lord-icon
					src="https://cdn.lordicon.com/jeqofpxi.json"
					trigger="loop"
					stroke="light"
					colors="primary:#285d32,secondary:#15803d"
					style="width:200px;height:200px; display:block; margin: 0 auto;">
				</lord-icon>
				<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Mission</h3>
				<p class="text-stone-700 leading-relaxed">
				To provide high-quality landscaping services that exceed our customers' expectations, transforming outdoor spaces into beautiful and functional environments. We are committed to using sustainable practices and innovative techniques to create gardens and green areas that improve the quality of life in the communities we serve.
				</p>
			</div>

			<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="200">
				<lord-icon
					src="https://cdn.lordicon.com/stqpqzpu.json"
					trigger="loop"
					stroke="light"
					colors="primary:#285d32,secondary:#15803d"
					style="width:200px;height:200px; display:block; margin: 0 auto;">
				</lord-icon>
				<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Vision</h3>
				<p class="text-stone-700 leading-relaxed">
				To be the leading landscaping company in Idaho, recognized for our excellence, innovation, and commitment to environmental sustainability. We aspire to be the trusted partner for residents and businesses seeking to transform their outdoor spaces into oases of beauty and tranquility.
				</p>
			</div>

			<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="400">
				<lord-icon
					src="https://cdn.lordicon.com/vmzmljdv.json"
					trigger="loop"
					stroke="light"
					colors="primary:#285d32,secondary:#15803d"
					style="width:200px;height:200px; display:block; margin: 0 auto;">
				</lord-icon>
				<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Values</h3>
				<p class="text-stone-700 leading-relaxed">
				Integrity, professionalism, and excellence guide every project we undertake. We value honesty in our relationships with clients, respect for the environment through eco-friendly practices, dedication to detail in every job, and social responsibility toward our communities.
				</p>
			</div>
        </div>
      </div>

		<HeroImage text="Where quality landscaping meets lasting beauty" image="aboutus2-greencountry.webp" />

		<Contenido4
			title = "Why choose us?"
			subtitle = "Quality and reliable services."
			contenido = { contenidoChoose }
			image = "aboutus3-greencountry.webp"
		/>

		<HeroImage text="High-quality materials and sustainable practices" image="aboutus5-greencountry.webp" />

		<Contenido3
			title="Meet Elias Rodriguez"
			subtitle="Owner & Founder of Green Country"
			contenido="With over 20 years of hands-on experience in the landscaping industry, Elias Rodriguez has built Green Country on a foundation of quality, integrity, and dedication. His passion for creating beautiful and functional outdoor spaces has helped homeowners and businesses across Idaho, including the Nampa area, transform their landscapes with confidence. Elias combines practical expertise, strong work ethic, and a commitment to excellence to ensure every project reflects the highest standards of craftsmanship and customer satisfaction. Under his leadership, Green Country continues to grow with the same values it was founded on — reliability, professionalism, and lasting results."
			image="aboutus4-greencountry.webp"
		/>

		<HeroImage text="Commitment to customer satisfaction and long-term results" image="aboutus6-greencountry.webp" />

		<Contenido4
			title = "Proudly serving Idaho"
			subtitle = "including the Nampa area"
			contenido = { contenidoServing }
			image = "aboutus7-greencountry.webp"
		/>

	  <CallToAction />
  <Footer client:load />
</MainLayout>
