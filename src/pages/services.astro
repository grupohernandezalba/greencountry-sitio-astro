---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";
import HeroImage from "../components/HeroImage.tsx";
import Contenido2 from "../components/Contenido2.tsx";
import Contenido3 from "../components/Contenido3.tsx";
import CallToAction from "../layouts/CallToAction.tsx";

---

<MainLayout>
  <Navbar client:load />
      <Banner title="Services" image="bannerservices-idaho-greencountry.webp" />

		<div class="bg-stone-100 mx-auto px-4 md:px-12 py-12">
			<div class="grid grid-cols-1 gap-8">
				<div class="flex flex-col justify-center" data-aos="fade-up">
					<h2 class="text-2xl md:text-4xl font-bold text-stone-800">
					Landscaping services
					</h2>
					<h3 class="text-lg md:text-2xl font-bold text-stone-800 mb-4">
						Quality work you can trust
					</h3>
					<p class="text-stone-700 leading-relaxed pb-6">
						We provide professional landscaping, hardscaping, lawn care, and nursery services designed to enhance and maintain beautiful outdoor spaces. Proudly serving Idaho, we deliver quality work you can trust.
					</p>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3">
				<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up">
					<lord-icon
						src="https://cdn.lordicon.com/eawkcgwr.json"
						trigger="loop"
						stroke="light"
						colors="primary:#0d542b,secondary:#00a63e"
						style="width:200px;height:200px; display:block; margin: 0 auto;">
					</lord-icon>
					<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Landscape</h3>
					<p class="text-stone-700 leading-relaxed">
						We design and install beautiful, functional landscapes tailored to your property and vision. From plant selection to complete outdoor transformations, our team delivers quality and lasting results.
					</p>
				</div>

				<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="200">
					<lord-icon
						src="https://cdn.lordicon.com/stqpqzpu.json"
						trigger="loop"
						stroke="light"
						colors="primary:#0d542b,secondary:#00a63e"
						style="width:200px;height:200px; display:block; margin: 0 auto;">
					</lord-icon>
					<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Hardscape</h3>
					<p class="text-stone-700 leading-relaxed">
					We design and install high-quality hardscape features such as patios, walkways, retaining walls, and outdoor living spaces. Our team combines creativity with technical expertise.
					</p>
				</div>

				<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="400">
					<lord-icon
						src="https://cdn.lordicon.com/dfarnxxi.json"
						trigger="loop"
						stroke="light"
						colors="primary:#0d542b,secondary:#00a63e"
						style="width:200px;height:200px; display:block; margin: 0 auto;">
					</lord-icon>
					<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Lawn care</h3>
					<p class="text-stone-700 leading-relaxed">
					We provide comprehensive lawn care services including mowing, fertilization, aeration, and pest control. Our team uses high-quality products and sustainable practices.
					</p>
				</div>
			</div>
		</div>

		<HeroImage text="Customized landscape and hardscape solutions" image="services1-greencountry.webp" />

		<Contenido2
			title = "Nursery products"
			subtitle = "Large inventory and immediate availability"
			contenido = "Our nursery offers a wide selection of high-quality trees, shrubs, ornamental plants, and seasonal varieties suited for Idaho’s climate. With several acres of growing space, we maintain a large inventory and immediate availability for residential and commercial projects. Whether you're looking for shade trees, privacy hedges, or decorative landscaping plants, we provide healthy, well-cared-for stock ready for pickup or installation."
			image = "services3-greencountry.webp"
		/>

		<HeroImage text="Your outdoor vision, expertly crafted." image="services4-greencountry.webp" />

	  <CallToAction />
  <Footer client:load />
</MainLayout>
