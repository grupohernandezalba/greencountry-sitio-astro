---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";
import CallToAction from "../layouts/CallToAction.tsx";

---

<MainLayout>
	<Navbar client:load />
	<Banner title="Thank You" image="bannercontact-greencountry.webp" />

	<div class="bg-stone-100 mx-auto px-4 md:px-12 pt-12">
		<div class="grid grid-cols-1 gap-8">
			<div class="flex flex-col justify-center" data-aos="fade-up">
				<h2 class="text-2xl md:text-4xl font-bold text-stone-800">
					Your message has been sent successfully!
				</h2>
				<h3 class="text-lg md:text-2xl font-bold text-stone-800 mb-4">
					Thank you for reaching out to Green Country Landscaping Services LLC. We will get back to you as soon as possible.
				</h3>
				<p class="text-stone-700 leading-relaxed">
					In the meantime, feel free to explore our website and learn more about our services. We look forward to working with you!
				</p>
			</div>
		</div>
	</div>

	<div class="bg-stone-100 grid grid-cols-1 md:grid-cols-3 gap-8 px-4 py-8">
		<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up">
			<lord-icon
				src="https://cdn.lordicon.com/mtisugol.json"
				trigger="loop"
				stroke="light"
				colors="primary:#0d542b,secondary:#00a63e"
				style="width:200px;height:200px; display:block; margin: 0 auto;">
			</lord-icon>
			<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Our address</h3>
			<address class="not-italic text-center text-stone-600">
				<a 
				href="https://maps.app.goo.gl/TVkk5i4TmypxN7Y6A" 
				target="_blank" 
				rel="noopener noreferrer" 
				class="crece"
				>
				18497 Midland Blvd. Nampa, Idaho <br />
				United States. ZIP 83687
				</a>
			</address>
		</div>

		<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="200">
			<lord-icon
				 src="https://cdn.lordicon.com/qsmqnggj.json"
				trigger="loop"
				stroke="light"
				colors="primary:#0d542b,secondary:#00a63e"
				style="width:200px;height:200px; display:block; margin: 0 auto;">
			</lord-icon>
			<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Call Us</h3>
			<a href="tel:+1208-477-7960" class="text-stone-700 leading-relaxed text-center block">
				208-477-7960
			</a>
		</div>

		<div class="bg-white md:m-4 p-8 mb-4 rounded-lg border border-stone-200" data-aos="fade-up" data-aos-delay="400">
			<lord-icon
				src="https://cdn.lordicon.com/azasiwss.json"
				trigger="loop"
				stroke="light"
				colors="primary:#0d542b,secondary:#00a63e"
				style="width:200px;height:200px; display:block; margin: 0 auto;">
			</lord-icon>
			<h3 class="text-center text-2xl font-bold text-stone-800 mb-4">Social media</h3>
			<p class="text-stone-700 leading-relaxed text-center">
				<a
					href="https://www.facebook.com/p/Green-country-lawn-care-100065310920759/"
					class="text-green-900 mx-auto inline-block "
					aria-label="Facebook"
					target="_blank"
					rel="noopener noreferrer"
					>
					<img src="/icons/facebook.svg" class="w-8 h-8 crece" />
                </a>
              <a
                href="#"
                class="text-green-900 mx-auto inline-block "
                aria-label="Instagram"
              >
                <img src="/icons/instagram.svg" class="w-8 h-8 crece" />
              </a>
			</p>
		</div>
	</div>
	</div>
	<CallToAction />
  	<Footer client:load />
</MainLayout>
