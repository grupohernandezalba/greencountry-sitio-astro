---
Astro.response.status = 404;
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";

---

<MainLayout>
	<Navbar client:load />
	<Banner title="404 - Página no encontrada" image="bannercontact-greencountry.webp" />

	<div class="bg-stone-100 mx-auto px-4 md:px-12 py-12">
		<div class="grid grid-cols-1 gap-8">
			<div class="flex flex-col justify-center" data-aos="fade-up">
				<h1>404 - Página no encontrada</h1>
        <p class="mt-4 text-lg text-gray-700">Lo sentimos, pero la página que estás buscando no existe.</p>
			</div>
		</div>
	</div>

  	<Footer client:load />
</MainLayout>
