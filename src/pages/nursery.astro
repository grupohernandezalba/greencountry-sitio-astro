---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../layouts/Navbar.tsx";
import Footer from "../layouts/Footer.tsx";
import Banner from "../components/Banner.tsx";
import HeroImage from "../components/HeroImage.tsx";
import Contenido4 from "../components/Contenido4.tsx";
import CallToAction from "../layouts/CallToAction.tsx";
import ImageGallery from "../components/ImageGallery.tsx";
import Texto from "../components/Texto.tsx";

const contenidoChoose = [
	"Maples trees",
	"Evergreens trees",
	"Cedrus trees ",
	"Ornamental trees ",
	"Juniperus trees ",
	"Arbovitas ",
	"Pinus nigra",
	"And more..."
];

const linksChoose = [
	"#",
	"#",
	"#",
	"#",
	"#",
	"#",
	"#",
	"#"
];

---

<MainLayout>
	<Navbar client:load />
		<Banner title="Nursery Products" image="bannernursery-greencountry.webp" />

		<Texto 
			title="Large inventory and immediate availability"
			contenido="Our nursery offers a wide selection of high-quality trees, shrubs, ornamental plants, and seasonal varieties suited for Idaho’s climate. With several acres of growing space, we maintain a large inventory and immediate availability for residential and commercial projects. Whether you're looking for shade trees, privacy hedges, or decorative landscaping plants, we provide healthy, well-cared-for stock ready for pickup or installation."
		/>

		<div class="container bg-white mx-auto px-4 py-12">
			<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
				<div class="grid gap-6" data-aos="fade-up">
					<div>
						<ImageGallery image="nurserygallery1-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery2-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery3-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="100">
					<div>
						<ImageGallery image="nurserygallery4-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery5-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery6-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="200">
					<div>
						<ImageGallery image="nurserygallery7-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery8-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery9-greencountry.webp" />
					</div>
				</div>
				<div class="grid gap-4" data-aos="fade-up" data-aos-delay="300">
					<div>
						<ImageGallery image="nurserygallery10-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery11-greencountry.webp" />
					</div>
					<div>
						<ImageGallery image="nurserygallery12-greencountry.webp" />
					</div>
				</div>
			</div>
		</div>

		<HeroImage text="Bringing life back to your landscape" image="nursery2-greencountry.webp" />

		<Contenido4
			title = "Locally grown"
			subtitle = "Explore our wide variety of trees and plants"
			contenido = { contenidoChoose }
			image = "nurserygallery13-greencountry.webp"
			links = { linksChoose }
		/>

		<HeroImage text="Built on quality and grown with care" image="nursery3-greencountry.webp" />

		<div class="container bg-white mx-auto px-4 py-12" data-aos="fade-up">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div>
					<video width="100%" controls poster="/img/poster1-greencountry.webp">
						<source src="/video/nursery-greencountry.mp4" type="video/mp4" />
						Your browser does not support the video tag.
					</video>
				</div>
				<div>
					<video width="100%" controls poster="/img/poster2-greencountry.webp">
						<source src="/video/nursery2-greencountry.mp4" type="video/mp4" />
						Your browser does not support the video tag.
					</video>
				</div>
				<div>
					<video width="100%" controls poster="/img/poster3-greencountry.webp">
						<source src="/video/nursery3-greencountry.mp4" type="video/mp4" />
						Your browser does not support the video tag.
					</video>
				</div>
			</div>
		</div>


		
	  <CallToAction />
  <Footer client:load />
</MainLayout>
