---
// Irrigation and drain services section.
// Matches the site's stone palette + Poppins/Inter fonts (loaded globally)
// and reuses the AOS "fade-up" animation used across the services page.

const services = [
  {
    title: "Sprinkler Repair",
    text: "Sprinkler repair service including system fixes to restore proper watering and lawn coverage.",
    image: "sprinklerrepair-greencountry.png",
    alt: "Technician repairing a sprinkler head",
  },
  {
    title: "New Sprinkler System Installation",
    text: "New sprinkler installation service including efficient lawn watering solutions.",
    image: "newsprinklerinstallation-greencountry.png",
    alt: "Technician installing a new sprinkler system",
  },
  {
    title: "French Drain Installation",
    text: "French drain installation service including drainage solutions to prevent water buildup.",
    image: "frenchdrain-greencountry.png",
    alt: "Technician installing a French drain",
  },
  {
    title: "Sprinkler Blowout",
    text: "Sprinkler blowout service including winter preparation to protect your irrigation system.",
    image: "sprinklerblowout-greencountry.png",
    alt: "Sprinkler spraying water across a lawn",
  },
  {
    title: "Sprinkler Start-Up",
    text: "Sprinkler startup service including system checks to ensure proper irrigation performance.",
    image: "sprinklerstartup-greencountry.png",
    alt: "Technician starting up a sprinkler system",
  },
];
---

<section class="bg-stone-100 px-4 md:px-12 py-12">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col justify-center mb-10" data-aos="fade-up">
      <h2 class="text-2xl md:text-4xl font-bold text-stone-800">
        Irrigation and drain services
      </h2>
      <h3 class="text-lg md:text-2xl font-bold text-stone-800 mt-2">
        Reliable solutions for efficient irrigation and proper drainage.
      </h3>
      <p class="text-stone-700 leading-relaxed mt-4 max-w-2xl">
        We provide system installation, repairs, maintenance, and drainage services
        to keep your landscape healthy and protected year-round.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s, i) => (
        <article
          class="bg-white rounded-lg border border-stone-200 p-4 flex gap-5 items-stretch hover:shadow-md transition-shadow"
          data-aos="fade-up"
          data-aos-delay={`${(i % 2) * 150}`}
        >
          <img
            src={`/img/${s.image}`}
            alt={s.alt}
            loading="lazy"
            class="w-28 md:w-32 shrink-0 rounded-md object-cover self-stretch min-h-[140px] bg-stone-200"
          />
          <div class="flex flex-col justify-center">
            <h3 class="text-xl md:text-2xl font-bold text-stone-800 mb-2">
              {s.title}
            </h3>
            <p class="text-stone-600 leading-relaxed text-sm md:text-base">
              {s.text}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
