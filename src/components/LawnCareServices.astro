---
// Lawn care services section.
// Matches the site's stone palette + Poppins/Inter fonts (loaded globally)
// and reuses the AOS "fade-up" animation used across the site.
// Includes the page header, so it replaces the existing top block on lawncare.astro.

const services = [
  {
    title: "Mowing",
    text: "Weekly lawn care service including mowing, edging, keep your lawn well maintained.",
    image: "mowing-greencountry 1.png",
    alt: "Technician mowing a lawn on a riding mower",
  },
  {
    title: "Fertilization",
    text: "Lawn fertilization service including nutrient treatments to promote healthy growth and keep your lawn green.",
    image: "project7-greencountry 1-2.png",
    alt: "Technician spreading fertilizer across a lawn",
  },
  {
    title: "Edging",
    text: "Professional lawn edging service including clean borders around sidewalks, driveways, and garden areas.",
    image: "edging-greencountry 1.png",
    alt: "Technician edging a lawn border",
  },
  {
    title: "Bush Trimming",
    text: "Regular bush trimming service including shaping and pruning to keep your shrubs healthy and neat.",
    image: "bushtrimming-greencountry-2 1.png",
    alt: "Technician trimming shrubs with a hedge trimmer",
  },
  {
    title: "Seasonal Cleanup",
    text: "Seasonal cleanup service including leaf removal, debris cleanup, and lawn preparation.",
    image: "seasonalcleanup-greencountry 1.png",
    alt: "Technician clearing leaves with a blower",
  },
  {
    title: "Lawn Pest & Weed Control Treatment",
    text: "Lawn pest control treatment including applications to protect your grass and lawn.",
    image: "lawnpestweedcontrol-greencountry 1.png",
    alt: "Lawn treatment protecting grass from pests and weeds",
  },
  {
    title: "Overseeding & Lawn Seeding",
    text: "Overseeding service including new grass growth to improve lawn density.",
    image: "overseeding-greencountry 1.webp",
    alt: "Technician overseeding a lawn with a spreader",
  },
  {
    title: "Premium Planter Weed Control",
    text: "Premium planter weed control service to prevent weeds and keep areas clean.",
    image: "premiumplanterweedcontrol-greencountry 1.png",
    alt: "Technician spraying weed control in a planter bed",
  },
  {
    title: "Planting Trees",
    text: "Tree planting service including proper installation and care recommendations to help trees grow healthy.",
    image: "plantingtrees-greencountry-4 1.png",
    alt: "Technician planting a young tree",
  },
  {
    title: "Planting / Installation",
    text: "Planting and installation service including sod, mulch, and professional placement of plants and landscape features.",
    image: "plantinginstallation-greencountry 1.png",
    alt: "Technician installing sod and landscape features",
  },
];
---

<section class="bg-stone-100 px-4 md:px-12 py-12">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col justify-center mb-10" data-aos="fade-up">
      <h2 class="text-2xl md:text-4xl font-bold text-stone-800">
        Lawn care services
      </h2>
      <h3 class="text-lg md:text-2xl font-bold text-stone-800 mt-2">
        Quality work you can trust
      </h3>
      <p class="text-stone-700 leading-relaxed mt-4 max-w-2xl">
        We provide comprehensive lawn care services including mowing, fertilization,
        aeration, and pest control. Our team uses high-quality products and sustainable practices.
      </p>
      <a  href="https://app.urable.com/form/QNnbmt80F0QyjZWrhi2D/ipUbzYWI67lZS41nzPZL"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 w-fit text-[#0d542b] font-semibold underline underline-offset-2 hover:text-[#0a3f20]"
      >
        Get a free estimate
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s, i) => (
        <article
          class="bg-white rounded-lg border border-stone-200 p-4 flex gap-5 items-stretch hover:shadow-md transition-shadow"
          data-aos="fade-up"
          data-aos-delay={`${(i % 2) * 150}`}
        >
          <img
            src={`/img/${s.image}`}
            alt={s.alt}
            loading="lazy"
            class="w-28 md:w-32 shrink-0 rounded-md object-cover self-stretch min-h-[140px] bg-stone-200"
          />
          <div class="flex flex-col justify-center">
            <h3 class="text-xl md:text-2xl font-bold text-stone-800 mb-2">
              {s.title}
            </h3>
            <p class="text-stone-600 leading-relaxed text-sm md:text-base">
              {s.text}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
