---
// Landscaping & hardscaping services carousel.
// Matches the site's stone palette + brand green (#0d542b), Poppins/Inter fonts
// (loaded globally in MainLayout) and reuses the AOS "fade-up" animation.
//
// IMAGES: each `image` points at the intended final filename under /public/img,
// following the site's naming convention (e.g. firepitinstallation-greencountry.webp).
// Those photos don't exist in the repo yet, so until you add them each card falls
// back (via onerror) to an existing image so the section never looks broken.
// Drop the real .webp in /public/img with the matching name and it swaps in
// automatically — no code change needed.

const services = [
  {
    title: "Flower, Plant, Shrub & Tree Installation.",
    text: "Professional planting that brings color, texture, and life to your yard, with healthy plants chosen to thrive in Idaho's climate and placed for lasting beauty.",
    image: "plant-intallation.jpg",
    alt: "Freshly planted trees and shrubs along a new garden bed",
  },
  {
    title: "Landscape Curbing Installation",
    text: "Durable concrete curbing that defines beds, walkways, and borders with clean, continuous lines, adding structure and lasting curb appeal to your property.",
    image: "curbing.jpg",
    alt: "Concrete landscape curbing edging a garden bed",
  },
  {
    title: "Full Landscape Build for New Homes",
    text: "Complete landscape design and installation for new construction, turning bare lots into finished, functional outdoor spaces ready to enjoy from day one.",
    image: "full-build-12.jpg",
    alt: "Newly landscaped yard around a recently built home",
  },
  {
    title: "Subdivision & HOA Landscape Maintenance",
    text: "Reliable, scheduled care for subdivisions and HOA communities, keeping shared green spaces clean, healthy, and consistently well-groomed all season long.",
    image: "project4-greencountry.webp",
    alt: "Well-maintained green common area in a residential community",
  },
  {
    title: "Yard Renovation",
    text: "Full yard makeovers that revive tired, overgrown spaces, refreshing plants, grading, and features to give your property a clean, modern new look.",
    image: "yardrenovation-greencountry.webp",
    alt: "Backyard mid-renovation with fresh landscaping",
  },
  {
    title: "Custom Fire Pit Installation",
    text: "Beautifully built fire pits designed to fit your space and style, creating a warm, inviting gathering spot you can enjoy in your backyard all year long.",
    image: "project5-greencountry.webp",
    alt: "Custom stone fire pit set into a paver patio",
  },
  {
    title: "Landscape Installation Services",
    text: "Expert installation of plants, sod, mulch, and features that brings your design to life with careful placement and quality materials built to last.",
    image: "project7-greencountry.webp",
    alt: "Crew installing sod and landscape features in a yard",
  },
  {
    title: "Custom Paver Installation",
    text: "Custom paver patios, walkways, and driveways installed with precision, combining durable materials and clean design to elevate your outdoor living space.",
    image: "paver.jpg",
    alt: "Freshly laid paver patio with clean joint lines",
  },
  {
    title: "Custom Retaining Wall Installation",
    text: "Sturdy, well-engineered retaining walls that manage slopes and erosion while adding structure, dimension, and lasting visual appeal to your landscape.",
    image: "retaining-wall.jpg",
    alt: "Stacked-block retaining wall on a graded slope",
  },
  {
    title: "Landscape Lighting Installation",
    text: "Professional outdoor lighting that highlights your landscape's best features, improving safety and ambiance so you can enjoy your yard into the evening.",
    image: "landscape-lightning.jpg",
    alt: "Warm landscape lighting illuminating a garden path at dusk",
  },
  {
    title: "Stone Steps Installation",
    text: "Natural stone steps built to balance beauty and function, creating safe, attractive transitions across slopes and elevation changes in your yard.",
    image: "stone-steps.jpg",
    alt: "Natural stone steps set into a landscaped slope",
  },
  {
    title: "Fence Installation",
    text: "Quality fence installation that adds privacy, security, and definition to your property, with durable materials and clean workmanship built to last.",
    image: "fence.jpg",
    alt: "Newly installed wood fence along a property line",
