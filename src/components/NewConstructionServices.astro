---
// New-construction / builder services section.
// Styled to match IrrigationServices.astro (stone palette, Poppins/Inter fonts
// loaded globally, AOS "fade-up"). Same white side-image cards, but each card
// adds a "Learn more" TEXT LINK (not a .boton pill) to the Urable estimate form.
//
// -------------------------------------------------------------------------
// EDIT ME: the client's message cut off at "Residential, Commercial & ...".
// Update the two lines below to the exact heading + subtitle they want.
const sectionTitle = "Residential, Commercial & New Construction";
const sectionSubtitle = "Complete landscape solutions for builders and communities.";
// -------------------------------------------------------------------------

// All three "Learn more" links point at the same estimate form for now.
// Give any card its own `href` to override the shared default.
const formHref = "https://app.urable.com/form/QNnbmt80F0QyjZWrhi2D/zNODElhUVki9OYVUUCpm";

const services: { title: string; text: string; image: string; alt: string; href?: string }[] = [
  {
    title: "Subdivision & HOA Landscape Maintenance",
    text: "Reliable, scheduled care for subdivisions and HOA communities, keeping shared green spaces clean, healthy, and consistently well-groomed all season long.",
    image: "project4-greencountry.webp",
    alt: "Well-maintained green common area in a residential community",
  },
  {
    title: "Builder Landscape Packages & New Construction Services",
    text: "Complete landscape packages for builders and new construction, delivering turnkey outdoor solutions that add value and curb appeal to every new home.",
    image: "services2-greencountry.webp",
    alt: "Landscaped front yard of a new-construction home",
  },
  {
    title: "Full Landscape Build for New Homes",
    text: "Complete landscape design and installation for new construction, turning bare lots into finished, functional outdoor spaces ready to enjoy from day one.",
    image: "full-build-12.jpg",
    alt: "Newly landscaped yard around a recently built home",
  },
];
---

<section class="bg-stone-100 px-4 md:px-12 py-12">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col justify-center mb-10" data-aos="fade-up">
      <h2 class="text-2xl md:text-4xl font-bold text-stone-800">
        {sectionTitle}
      </h2>
      <h3 class="text-lg md:text-2xl font-bold text-stone-800 mt-2">
        {sectionSubtitle}
      </h3>
      <p class="text-stone-700 leading-relaxed mt-4 max-w-2xl">
        From subdivisions and HOA communities to full builds for brand-new homes,
        we deliver dependable, turnkey landscaping that adds lasting value and curb
        appeal to residential, commercial, and new-construction projects.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s, i) => (
        <article
          class="bg-white rounded-lg border border-stone-200 p-4 flex gap-5 items-stretch hover:shadow-md transition-shadow"
          data-aos="fade-up"
          data-aos-delay={`${(i % 2) * 150}`}
        >
          <img
            src={`/img/${s.image}`}
            alt={s.alt}
            loading="lazy"
            class="w-28 md:w-32 shrink-0 rounded-md object-cover self-stretch min-h-[140px] bg-stone-200"
          />
          <div class="flex flex-col justify-center">
            <h3 class="text-xl md:text-2xl font-bold text-stone-800 mb-2">
              {s.title}
            </h3>
            <p class="text-stone-600 leading-relaxed text-sm md:text-base">
              {s.text}
            </p>
            <a
              href={s.href ?? formHref}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex items-center gap-1 w-fit text-[#0d542b] font-semibold hover:underline underline-offset-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0d542b]"
            >
              Get a free quote
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
